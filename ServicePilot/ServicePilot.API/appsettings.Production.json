{
  // ── PRODUCTION CONFIGURATION ──────────────────────────────────────────────
  // This file sets non-secret production values (log levels, CORS origins).
  // ALL secrets must be injected via environment variables — never commit
  // real passwords or keys to source control.
  //
  // Required environment variables on the production server:
  //
  //   JwtSettings__Secret=<min-32-char-cryptographically-random-string>
  //   ConnectionStrings__DefaultConnection=Host=prod-db;Port=5432;Database=servicepilot_db;Username=sp_prod;Password=<strong-password>
  //   SuperAdmin__ApiKey=<min-32-char-cryptographically-random-string>
  //
  // Generate strong secrets with:
  //   openssl rand -base64 48
  // ─────────────────────────────────────────────────────────────────────────

  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },

  "Cors": {
    "AllowedOrigins": [
      "https://servicepilot-dashboard.vercel.app"
    ]
  },

  "App": {
    "BaseUrl": "https://servicepilot-dashboard.vercel.app"
  }
}

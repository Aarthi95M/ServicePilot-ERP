{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "JwtSettings": {
    // Secret MUST be overridden via environment variable or appsettings.Development.json.
    // In production set: JwtSettings__Secret=<min-32-char-random-string>
    "Secret": "",
    "Issuer": "ServicePilot",
    "Audience": "ServicePilotUsers",
    "ExpiryMinutes": 60
  },

  "ConnectionStrings": {
    // Connection string MUST be overridden via environment variable or appsettings.Development.json.
    // In production set: ConnectionStrings__DefaultConnection=Host=...
    "DefaultConnection": ""
  },

  // CORS: list all origins allowed to call the API.
  // Development values are here. Override AllowedOrigins in appsettings.Production.json
  // or via environment variable: Cors__AllowedOrigins__0=https://app.yourdomain.com
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },

  // SuperAdmin API key — protects /api/superadmin/* endpoints.
  // Callers must send header: X-Api-Key: <this value>
  // In production set: SuperAdmin__ApiKey=<strong-random-value>
  "SuperAdmin": {
    "ApiKey": ""
  },

  // Base URL of the frontend app — used in password-reset email links.
  // In production set: App__BaseUrl=https://app.servicepilot.ae
  "App": {
    "BaseUrl": "http://localhost:3000"
  }
}

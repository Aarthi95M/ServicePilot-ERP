# Copy this file to .env.local and fill in YOUR machine's LAN IP.
# Find it by running:  ipconfig  (Windows)  or  ifconfig  (Mac/Linux)
# Look for the IPv4 Address under your Wi-Fi or Ethernet adapter.
#
# Example:
#   EXPO_PUBLIC_API_URL=http://192.168.1.172:5113/api
#
# Then restart Metro:  npx expo start --clear

EXPO_PUBLIC_API_URL=http://192.168.1.172:5113/api
